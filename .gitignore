# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

#ux
ux/node_modules

# Python Section
__pycache__/
venv/

# Ignore bot.py in py_grpc_server as it is a temporary file
py_grpc_server/bot.py

# This is what is passed to the bot, do not override
tmp/
.DS_Store
.ipynb_checkpoints/

build/
blitz_env.egg-info/
blitz_env/agent_pb2_grpc.py
blitz_env/agent_pb2.py
blitz_env/agent_pb2.pyi
sheets-creds.json

# Generated gRPC stubs in py_grpc_server (regenerated by `make gen-python-only`)
py_grpc_server/agent_pb2_grpc.py
py_grpc_server/agent_pb2.py
py_grpc_server/agent_pb2.pyi

# Build-copied into blitz_env by `make build-py-module` (source of truth is repo root)
blitz_env/player_ranks_*.csv
blitz_env/loadPlayers.py

# Ignore any env files that could accidentally be merged in
*.env

dist/*
# Local simulator artifacts created at the repo root by the harness
# (DatabaseManager defaults to ./gamestate.db). Tracked DBs live under data/.
/gamestate.db
/stats.db
